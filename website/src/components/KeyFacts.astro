---
const facts = [
  { icon: '📅', label: 'June 2027' },
  { icon: '📍', label: 'Madison, WI' },
  { icon: '👥', label: '~XXX attendees' },
  { icon: '🎤', label: 'N+ talks · parallel tracks' },
];
---
<section class="bg-ossfe-dark py-12">
  <div class="mx-auto grid max-w-5xl grid-cols-2 gap-8 px-6 md:grid-cols-4">
    {facts.map((f) => (
      <div class="text-center">
        <div class="text-3xl">{f.icon}</div>
        <div class="mt-2 font-body text-ink-muted">{f.label}</div>
      </div>
    ))}
  </div>
</section>