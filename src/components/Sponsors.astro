---
// src/components/Sponsors.astro — HOME PAGE TEASER (links to /sponsors)

// Just the headline tier prices for a quick glance.
const tiers = [
  { name: 'Silver', price: '$2,000' },
  { name: 'Gold', price: '$5,000', featured: true },
  { name: 'Diamond', price: '$10,000' },
];

const confirmedSponsors = []; // add { name, logo } as they sign
---

<section id="sponsors" class="bg-ossfe-dark py-24">
  <div class="mx-auto max-w-5xl px-6 text-center">

    <p class="font-body text-sm uppercase tracking-widest text-accent">Partner with us</p>
    <h2 class="mt-3 font-display text-4xl text-ink md:text-5xl">Sponsor OSSFE 2027</h2>
    <p class="mx-auto mt-4 max-w-2xl font-body text-ink-muted">
      Put your brand in front of the open-source fusion community — researchers, national labs
      and startups — and help sustain the tools the field depends on.
    </p>

    <!-- Quick tier glance -->
    <div class="mt-12 grid gap-4 sm:grid-cols-3">
      {tiers.map((t) => (
        <div class={`rounded-2xl p-6 ring-1 transition
          ${t.featured ? 'bg-ossfe-blue ring-accent/60' : 'bg-ossfe-blue/50 ring-white/10'}`}>
          <div class="font-display text-xl text-ink">{t.name}</div>
          <div class="mt-1 font-display text-2xl text-accent">{t.price}</div>
        </div>
      ))}
    </div>

    <!-- Confirmed sponsors / coming-soon -->
    <div class="mt-14">
      {confirmedSponsors.length > 0 ? (
        <div class="flex flex-wrap items-center justify-center gap-10">
          {confirmedSponsors.map((s) => (
            <img src={s.logo} alt={s.name}
                 class="h-10 opacity-70 grayscale transition hover:opacity-100 hover:grayscale-0" />
          ))}
        </div>
      ) : (
        <p class="font-body text-ink-faint">
          Sponsor line-up coming soon — <span class="text-ink-muted">your logo could be here.</span>
        </p>
      )}
    </div>

    <!-- CTA to full page -->
    <div class="mt-12 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <a href="/sponsors"
         class="rounded-full bg-accent px-8 py-3 font-body font-semibold text-ossfe-darker transition hover:bg-accent-hover">
        See sponsorship options →
      </a>
      <a href="mailto:sponsors@ossfe.org"
         class="rounded-full border border-ink/30 px-8 py-3 font-body font-semibold text-ink transition hover:border-ink hover:bg-ink/10">
        sponsors@ossfe.org
      </a>
    </div>

  </div>
</section>