---
// src/components/WhyAttend.astro
const benefits = [
  {
    icon: '🗣️',
    title: 'Parallel sessions',
    body: 'Multiple tracks running side by side — from plasma codes to neutronics, ML and HPC — so there’s always something relevant to you.',
  },
  {
    icon: '🎤',
    title: 'Invited speakers',
    body: 'Keynotes and invited talks from leaders shaping open-source software across the fusion community.',
  },
  {
    icon: '🛠️',
    title: 'Hands-on tutorials',
    body: 'Roll up your sleeves and learn the tools directly from the people who build and maintain them.',
  },
  {
    icon: '🤝',
    title: 'Real networking',
    body: 'Meet maintainers, researchers, national labs and startups — the connections that turn into collaborations.',
  },
  {
    icon: '📊',
    title: 'Posters & demos',
    body: 'Show your work, get feedback, and discover what others across the field are building.',
  },
  {
    icon: '🌱',
    title: 'Welcoming to all',
    body: 'Novice to expert, student to PI — with travel grants and scholarships to help you get there.',
  },
];
---

<section id="why-attend" class="bg-ossfe-blue py-24">
  <div class="mx-auto max-w-6xl px-6">

    <div class="mx-auto max-w-2xl text-center">
      <p class="font-body text-sm uppercase tracking-widest text-accent">Why attend</p>
      <h2 class="mt-3 font-display text-4xl text-ink md:text-5xl">
        Three days that move the field forward
      </h2>
      <p class="mt-4 font-body text-ink-muted">
        Whether you write the code, run it, or fund it — OSSFE is where the open-source fusion
        community comes together.
      </p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {benefits.map((b) => (
        <div class="group rounded-2xl bg-ossfe-dark/60 p-8 ring-1 ring-white/5 transition hover:-translate-y-1 hover:ring-accent/40">
          <div class="text-4xl transition group-hover:scale-110">{b.icon}</div>
          <h3 class="mt-5 font-display text-xl text-ink">{b.title}</h3>
          <p class="mt-3 font-body text-sm leading-relaxed text-ink-faint">{b.body}</p>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-16 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <a href="#register"
         class="rounded-full bg-accent px-8 py-3 font-body font-semibold text-ossfe-darker transition hover:bg-accent-hover">
        Register
      </a>
      <a href="#cfp"
         class="rounded-full border border-ink/30 px-8 py-3 font-body font-semibold text-ink transition hover:border-ink hover:bg-ink/10">
        Submit a talk
      </a>
    </div>

  </div>
</section>