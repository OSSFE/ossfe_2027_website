<style>
  .ossfe-logo { width: 100%; height: auto; display: block; }

  .ossfe-text {
    opacity: 0;
    animation: ossfe-fade 0.6s ease forwards;
  }

  .commit-line {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    animation: ossfe-draw 0.6s ease forwards;
  }

  .commit-dot {
    opacity: 0;
    transform-box: fill-box;
    transform-origin: center;
    animation: ossfe-pop 0.35s cubic-bezier(.34,1.56,.64,1) forwards;
  }

  @keyframes ossfe-fade { to { opacity: 1; } }
  @keyframes ossfe-draw { to { stroke-dashoffset: 0; } }
  @keyframes ossfe-pop {
    0%   { opacity: 0; transform: scale(0); }
    100% { opacity: 1; transform: scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .ossfe-text, .commit-dot { opacity: 1; animation: none; }
    .commit-line { stroke-dashoffset: 0; animation: none; }
  }
</style>