---
// src/components/Timeline.astro
// status: 'done' | 'next' | 'upcoming' | 'tba'
const milestones = [
  { date: 'Soon',        label: 'CFP opens',            status: 'tba' },
  { date: 'Soon',        label: 'CFP closes',           status: 'tba' },
  { date: 'Dec 2026',    label: 'Early-bird tickets',   status: 'tba' },
  { date: 'Mar 2027',    label: 'Speakers notified',    status: 'tba' },
  { date: 'Apr 2027',    label: 'Program published',    status: 'tba' },
  { date: 'May/Jun 2027',    label: 'OSSFE 2027 · Madison', status: 'tba' },
];

const dotClass = {
  done:     'bg-accent border-accent',
  next:     'bg-accent border-accent animate-pulse',
  upcoming: 'bg-ossfe-dark border-ink/30',
  tba:      'bg-ossfe-dark border-dashed border-ink/40',
};
---

<section id="timeline" class="bg-ossfe-dark py-24">
  <div class="mx-auto max-w-6xl px-6">

    <div class="text-center">
      <p class="font-body text-sm uppercase tracking-widest text-accent">Key dates</p>
      <h2 class="mt-3 font-display text-4xl text-ink md:text-5xl">Save the dates</h2>
      <p class="mx-auto mt-4 max-w-xl font-body text-ink-faint">
        Dates are being finalised: sign up below to get notified the moment the CFP opens.
      </p>
    </div>

    <!-- Desktop: horizontal stepper -->
    <ol class="mt-16 hidden md:flex md:items-start md:justify-between">
      {milestones.map((m, i) => (
        <li class="relative flex flex-1 flex-col items-center text-center">
          <!-- connector line (not after last item) -->
          {i < milestones.length - 1 && (
            <span class="absolute left-1/2 top-3 -z-0 h-0.5 w-full bg-white/15"></span>
          )}
          <span class={`relative z-10 h-6 w-6 rounded-full border-2 ${dotClass[m.status]}`}></span>
          <span class="mt-4 font-display text-sm text-accent">{m.date}</span>
          <span class="mt-1 px-2 font-body text-sm text-ink-muted">{m.label}</span>
        </li>
      ))}
    </ol>

    <!-- Mobile: vertical stepper -->
    <ol class="mt-12 space-y-8 md:hidden">
      {milestones.map((m, i) => (
        <li class="relative flex gap-4 pl-2">
          {i < milestones.length - 1 && (
            <span class="absolute left-[1.4rem] top-6 h-full w-0.5 bg-white/15"></span>
          )}
          <span class={`relative z-10 mt-1 h-5 w-5 flex-shrink-0 rounded-full border-2 ${dotClass[m.status]}`}></span>
          <div>
            <div class="font-display text-sm text-accent">{m.date}</div>
            <div class="font-body text-ink-muted">{m.label}</div>
          </div>
        </li>
      ))}
    </ol>

    <!-- CTA -->
    <div class="mt-16 text-center">
      <a href="#newsletter"
         class="rounded-full bg-accent px-8 py-3 font-body font-semibold text-ossfe-darker transition hover:bg-accent-hover">
        Notify me when the CFP opens
      </a>
    </div>

  </div>
</section>