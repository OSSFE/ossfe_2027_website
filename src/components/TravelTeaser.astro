---
// src/components/TravelTeaser.astro
const infoCards = [
  { icon: '🏨', title: 'Hotels & lodging', body: 'Discounted room blocks near the venue — booking details coming soon.' },
  { icon: '✈️', title: 'Getting there', body: 'Madison (MSN) airport, with Chicago (ORD/MDW) a few hours away by road or rail.' },
  { icon: '📄', title: 'Visa & invitation letters', body: 'Travelling internationally? We provide invitation letters on request.' },
  { icon: '👨‍👩‍👧', title: 'Family & accessibility', body: 'Family support, a nursing room and accessible facilities — just ask.' },
];
---

<section id="travel" class="bg-ossfe-dark py-24">
  <div class="mx-auto max-w-6xl px-6">

    <div class="grid items-center gap-12 lg:grid-cols-2">

      {/* LEFT — intro + cards */}
      <div>
        <p class="font-body text-sm uppercase tracking-widest text-accent">Travel & venue</p>
        <h2 class="mt-3 font-display text-4xl text-ink md:text-5xl">See you in Madison</h2>
        <p class="mt-4 font-body text-ink-muted">
          A vibrant, walkable city on the lakes — and a welcoming home for OSSFE 2027.
          Everything you need to plan your trip will live here.
        </p>

        <div class="mt-10 grid gap-4 sm:grid-cols-2">
          {infoCards.map((c) => (
            <div class="rounded-2xl bg-ossfe-blue/60 p-5 ring-1 ring-white/5">
              <div class="text-2xl">{c.icon}</div>
              <h3 class="mt-3 font-display text-lg text-ink">{c.title}</h3>
              <p class="mt-1 font-body text-sm text-ink-faint">{c.body}</p>
            </div>
          ))}
        </div>

        <div class="mt-10">
          <a href="/travel"
             class="inline-flex items-center gap-2 rounded-full bg-accent px-8 py-3 font-body font-semibold text-ossfe-darker transition hover:bg-accent-hover">
            Plan your trip →
          </a>
        </div>
      </div>

      {/* RIGHT — Madison image */}
      <div class="relative aspect-[4/3] overflow-hidden rounded-2xl ring-1 ring-white/10">
        <img
          src="/images/madison.jpg"
          alt="Madison, Wisconsin"
          loading="lazy"
          class="h-full w-full object-cover"
        />
        <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ossfe-darker/70 via-transparent to-transparent"></div>
        <span class="absolute bottom-4 left-5 font-display text-xl text-ink drop-shadow">
          Madison, Wisconsin
        </span>
      </div>

    </div>

  </div>
</section>