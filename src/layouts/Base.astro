---
import '../styles/global.css';
const { title = 'OSSFE 2027 — Open Source Software for Fusion Energy' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="OSSFE 2027 — the conference for open-source software in fusion energy. Madison, Wisconsin, June 2027." />
    <!-- Open Graph / social cards -->
    <meta property="og:title" content={title} />
    <meta property="og:image" content={new URL(`${base}media/hero-poster.jpg`, Astro.site)} />
    <link rel="icon" href={`${base}favicon.svg?v=3`} type="image/svg+xml" />
  </head>
  <body class="bg-ossfe-blue font-body text-ink antialiased">
    <slot />
  </body>
</html>