---
// src/pages/sponsors.astro
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;

// ────────────────────────────────────────────────
//  EDIT YOUR DATA HERE  (placeholders = 2026 / projected)
// ────────────────────────────────────────────────
const headline = [
  { value: '250+', label: 'Attendees in 2026' },
  { value: '30+', label: 'Countries represented' },
  { value: '60+', label: 'Talks, tutorials & posters' },
  { value: '1.2k', label: 'Newsletter subscribers' },
];

const audience = [
  { label: 'Academia', pct: 38 },
  { label: 'National labs', pct: 27 },
  { label: 'Industry & startups', pct: 23 },
  { label: 'Students', pct: 12 },
];

const growth = [
  { year: '2024', value: 90 },
  { year: '2025', value: 160 },
  { year: '2026', value: 250 },
  { year: '2027', value: 350, projected: true },
];

const reach = [
  { icon: '🌐', value: '15k', label: 'Website visits' },
  { icon: '▶️', value: '8k', label: 'Talk recording views' },
  { icon: '💬', value: '3k', label: 'Social followers' },
];

const tiers = [
  { name: 'Silver', price: '$2,000', includes: null,
    perks: ['Logo on website & sponsor banner', 'Job board listing', 'Distribute merch in attendee bags', '1 conference pass'], featured: false },
  { name: 'Gold', price: '$5,000', includes: 'Silver',
    perks: ['Expo booth', 'Attendee list & résumés (opt-in)', '1 scholarship in your name', '2 conference passes'], featured: true },
  { name: 'Diamond', price: '$10,000', slots: 'only 3', includes: 'Gold',
    perks: ['Premium logo + top billing', 'Logo on badges & lanyards', 'Offer a tutorial', '2 scholarships in your name', '3 conference passes'], featured: false },
];

const alaCarte = [
  { item: 'Welcome reception', price: '$3,000' },
  { item: 'Coffee / refreshment break', price: '$2,000' },
  { item: 'Lanyards (exclusive)', price: '$4,000' },
  { item: 'Travel-grant pool', price: 'any amount' },
];

const faqs = [
  { q: "What's included with an expo booth?", a: 'A table, chairs, wi-fi and power in a high-traffic common area. Sponsors handle their own shipping. Available to Gold and Diamond.' },
  { q: 'What is premium logo placement?', a: 'Preferential treatment on all logo benefits (first/centered/larger), plus your logo on attendee badges and lanyards.' },
  { q: 'What is top billing?', a: 'Diamond sponsors are always listed first and acknowledged as “Special Thanks to our Diamond Sponsors”.' },
  { q: 'How does the attendee list work?', a: 'A CSV (name, email, job title, company) of attendees who opt in at registration. Gold and Diamond only.' },
  { q: 'Do sponsor talks go through review?', a: 'Diamond tutorial slots don’t go through the open CFP, but content is approved by the committee for relevance.' },
];
const max = Math.max(...growth.map((g) => g.value));
---

<Base title="Sponsor OSSFE 2027">
  <Nav />

  <!-- HERO -->
  <header class="bg-ossfe-blue pt-32 pb-20">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <p class="font-body text-sm uppercase tracking-widest text-accent">Sponsor Prospectus</p>
      <h1 class="mt-3 font-display text-5xl text-ink md:text-6xl">Partner with OSSFE 2027</h1>
      <p class="mx-auto mt-6 max-w-2xl font-body text-lg text-ink-muted">
        OSSFE is the conference for the open-source software powering fusion energy. Sponsoring
        connects your brand with a highly technical, hard-to-reach community — and helps sustain
        the tools the whole field relies on.
      </p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href={`${base}sponsor-prospectus.pdf`} class="rounded-full bg-accent px-8 py-3 font-semibold text-ossfe-darker transition hover:bg-accent-hover">Download PDF</a>
        <a href="mailto:sponsors@ossfe.org" class="rounded-full border border-ink/30 px-8 py-3 font-semibold text-ink transition hover:border-ink hover:bg-ink/10">sponsors@ossfe.org</a>
      </div>
    </div>
  </header>

  <!-- HEADLINE STATS -->
  <section class="bg-ossfe-dark py-16">
    <div class="mx-auto grid max-w-5xl grid-cols-2 gap-8 px-6 md:grid-cols-4">
      {headline.map((s) => (
        <div class="text-center">
          <div class="font-display text-4xl text-accent md:text-5xl">{s.value}</div>
          <div class="mt-2 font-body text-sm text-ink-faint">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- WHY SPONSOR -->
  <section class="bg-ossfe-blue py-20">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="text-center font-display text-4xl text-ink">Why sponsor?</h2>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {[
          { icon: '🎯', t: 'Reach a niche audience', b: 'Direct access to fusion software engineers, scientists and decision-makers you can’t easily reach elsewhere.' },
          { icon: '🧲', t: 'Find rare talent', b: 'Meet and recruit specialists at the intersection of fusion, scientific computing and open source.' },
          { icon: '🌱', t: 'Make real impact', b: 'Your support funds travel grants, scholarships and the open-source tools the community depends on.' },
        ].map((c) => (
          <div class="rounded-2xl bg-ossfe-dark/60 p-8 ring-1 ring-white/5">
            <div class="text-3xl">{c.icon}</div>
            <h3 class="mt-4 font-display text-xl text-ink">{c.t}</h3>
            <p class="mt-2 font-body text-sm text-ink-faint">{c.b}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DATA: AUDIENCE + GROWTH -->
  <section class="bg-ossfe-dark py-20">
    <div class="mx-auto grid max-w-6xl gap-16 px-6 md:grid-cols-2">

      <!-- Audience breakdown (horizontal bars) -->
      <div>
        <h3 class="font-display text-2xl text-ink">Who attends</h3>
        <p class="mt-2 font-body text-sm text-ink-faint">2026 audience breakdown</p>
        <div class="mt-8 space-y-5">
          {audience.map((a) => (
            <div>
              <div class="flex justify-between font-body text-sm text-ink-muted">
                <span>{a.label}</span><span class="text-accent">{a.pct}%</span>
              </div>
              <div class="mt-2 h-3 w-full overflow-hidden rounded-full bg-white/10">
                <div class="h-full rounded-full bg-accent" style={`width:${a.pct}%`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Growth (vertical bars) -->
      <div>
        <h3 class="font-display text-2xl text-ink">Growing fast</h3>
        <p class="mt-2 font-body text-sm text-ink-faint">Attendance by year (2027 projected)</p>
        <div class="mt-8 flex h-56 items-end justify-between gap-4">
          {growth.map((g) => (
            <div class="flex flex-1 flex-col items-center justify-end">
              <span class="mb-2 font-body text-sm text-ink-muted">{g.value}</span>
              <div
                class={`w-full rounded-t-lg ${g.projected ? 'bg-accent/40 ring-1 ring-accent ring-dashed' : 'bg-accent'}`}
                style={`height:${(g.value / max) * 100}%`}>
              </div>
              <span class="mt-2 font-body text-xs text-ink-faint">{g.year}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Online reach strip -->
    <div class="mx-auto mt-16 grid max-w-4xl grid-cols-3 gap-6 px-6">
      {reach.map((r) => (
        <div class="rounded-2xl bg-ossfe-blue/60 p-6 text-center ring-1 ring-white/5">
          <div class="text-2xl">{r.icon}</div>
          <div class="mt-2 font-display text-3xl text-ink">{r.value}</div>
          <div class="font-body text-xs text-ink-faint">{r.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- TIERS -->
  <section class="bg-ossfe-blue py-20">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="text-center font-display text-4xl text-ink">Sponsorship tiers</h2>
      <p class="mt-3 text-center font-body text-ink-faint">All amounts in USD. Each tier builds on the one below.</p>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {tiers.map((t) => (
          <div class={`relative flex flex-col rounded-2xl p-8 ring-1 transition
            ${t.featured ? 'bg-ossfe-dark ring-accent/60 md:-translate-y-2' : 'bg-ossfe-dark/50 ring-white/10'}`}>
            {t.featured && (
              <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-accent px-4 py-1 text-xs font-semibold text-ossfe-darker">Most popular</span>
            )}
            <h3 class="font-display text-2xl text-ink">{t.name}</h3>
            <div class="mt-2 flex items-baseline gap-2">
              <span class="font-display text-3xl text-ink">{t.price}</span>
              {t.slots && <span class="font-body text-xs text-accent">{t.slots}</span>}
            </div>
            {t.includes
              ? <p class="mt-5 rounded-lg bg-accent/10 px-3 py-2 font-body text-sm font-semibold text-accent">✦ Everything in {t.includes}, plus:</p>
              : <p class="mt-5 font-body text-sm text-ink-faint">Includes:</p>}
            <ul class="mt-4 space-y-3">
              {t.perks.map((p) => (
                <li class="flex items-start gap-2 font-body text-sm text-ink-muted"><span class="text-accent">✓</span><span>{p}</span></li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- À la carte -->
      <div class="mt-16">
        <h3 class="text-center font-display text-2xl text-ink">À la carte add-ons</h3>
        <div class="mx-auto mt-8 max-w-2xl divide-y divide-white/10 rounded-2xl bg-ossfe-dark/50 ring-1 ring-white/10">
          {alaCarte.map((a) => (
            <div class="flex items-center justify-between px-6 py-4">
              <span class="font-body text-ink-muted">{a.item}</span>
              <span class="font-display text-accent">{a.price}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-ossfe-dark py-20">
    <div class="mx-auto max-w-3xl px-6">
      <h2 class="text-center font-display text-4xl text-ink">Sponsor FAQ</h2>
      <div class="mt-10 space-y-3">
        {faqs.map((f) => (
          <details class="group rounded-xl bg-ossfe-blue/60 p-5 ring-1 ring-white/5">
            <summary class="cursor-pointer list-none font-body font-semibold text-ink marker:hidden">
              <span class="text-accent">＋</span> {f.q}
            </summary>
            <p class="mt-3 font-body text-sm text-ink-faint">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-ossfe-blue py-20">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <h2 class="font-display text-4xl text-ink">Ready to partner with OSSFE?</h2>
      <p class="mt-4 font-body text-ink-muted">Tiers are limited and assigned first-come, first-served. Let’s talk.</p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a href={`${base}sponsor-prospectus.pdf`} class="rounded-full bg-accent px-8 py-3 font-semibold text-ossfe-darker transition hover:bg-accent-hover">Download the prospectus</a>
        <a href="mailto:sponsors@ossfe.org" class="rounded-full border border-ink/30 px-8 py-3 font-semibold text-ink transition hover:border-ink hover:bg-ink/10">Email sponsors@ossfe.org</a>
      </div>
    </div>
  </section>

  <Footer />
</Base>